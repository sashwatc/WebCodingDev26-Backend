# Copy this file to .env.local for local development.
# In deployment, set these as environment variables/secrets in your host.
# Never commit real passwords or API keys.

# Required: MongoDB connection
MONGO_URI=fill_this_in
MONGO_DATABASE=lostthenfound

# App settings
PORT=8080
FRONTEND_URL=fill_this_in
ADMIN_EMAIL=fill_this_in
SEED_DATA_ENABLED=true

# Appwrite browser auth
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=fill_this_in

# Recovery Center, Pattern Review, and demo scenarios use the same admin
# header/auth flow and seed setting. No paid external service is required.

# AI matchmaking
AI_MATCHMAKING_ENABLED=true
AI_API_KEY=fill_this_in
AI_MATCHMAKING_MAX_CANDIDATES=8
AI_MATCHMAKING_MIN_CONFIDENCE=35

# Use this if your AI key is from OpenRouter, like sk-or-v1-...
AI_MATCHMAKING_BASE_URL=https://openrouter.ai/api/v1/chat/completions
AI_MATCHMAKING_MODEL=openai/gpt-5.4-mini

# Use these instead if your AI key is directly from OpenAI, like sk-proj-...
# AI_MATCHMAKING_BASE_URL=https://api.openai.com/v1/chat/completions
# AI_MATCHMAKING_MODEL=gpt-5.4-mini

# Recovery Pulse notification workflow
# Default mock mode records realistic delivery rows without contacting providers.
NOTIFICATIONS_MODE=mock

EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=lostthenfound@pvhs.demo

SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=

# Legacy pickup display defaults used by Return Pass records.
PICKUP_LOCATION=PVHS Main Office pickup station
PICKUP_HOURS=School days, 8:00 AM-3:30 PM
